# ══════════════════════════════════════════════════════════════════
# DataWhisperer — Environment Variables Template
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file — it is gitignored.
# ══════════════════════════════════════════════════════════════════

# ── Groq LLM API Keys ───────────────────────────────────────────
# Comma-separated pool. The system auto-rotates on rate limits.
GROQ_API_KEYS=gsk_your_key_1,gsk_your_key_2


# ── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
