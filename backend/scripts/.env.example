# ── Database Seeding Scripts ────────────────────────────────────────
# These env vars are ONLY needed if you want to run the seed scripts
# in backend/scripts/ to populate remote cloud databases with sample data.
# They are NOT required for normal operation of DataWhisperer.

# ── Aiven MySQL ────────────────────────────────────────────────────
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_HOST=your_mysql_host.aivencloud.com
MYSQL_PORT=25235
MYSQL_DATABASE=defaultdb

# ── Supabase (PostgreSQL) ──────────────────────────────────────────
SUPABASE_USER=your_supabase_user
SUPABASE_PASSWORD=your_supabase_password
SUPABASE_HOST=your_project.pooler.supabase.com
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres

# ── Turso (libSQL) ─────────────────────────────────────────────────
TURSO_HOST=your_db.turso.io
TURSO_AUTH_TOKEN=your_turso_jwt_token

# ── TiDB Cloud ─────────────────────────────────────────────────────
TIDB_USER=your_tidb_user
TIDB_PASSWORD=your_tidb_password
TIDB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_DATABASE=fortune500
